PORT=3001
# Connection string do Postgres (Neon, Supabase, Render Postgres, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# Para desabilitar SSL (não recomendado em produção):
# PGSSL=disable
JWT_SECRET=segredo_forte_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d
WEBHOOK_API_KEY=chave_secreta_para_n8n
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
TELEGRAM_BOT_TOKEN=coloque_o_token_do_botfather_aqui
# Se RUN_INTERNAL_CRON=true, o app roda node-cron internamente (bom para dev / hosts sem sleep).
# Em Render free (que dorme), deixe false e use cron-job.org chamando POST /cron/tick.
RUN_INTERNAL_CRON=false
NOTIFICACAO_CRON=0 9 * * *
# Segredo para autenticar o cron externo. Header: x-cron-secret
CRON_SECRET=troque_por_um_segredo_aleatorio
